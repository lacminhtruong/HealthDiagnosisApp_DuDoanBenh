@model BenhNhan

<h2>Chẩn đoán bệnh bằng thuật toán KNN</h2>

<form asp-action="KetQua" method="post">
    <div class="form-group">
        <label>Triệu chứng:</label>
        <div class="trieu-chung-list">
            @foreach (var trieuChung in TrieuChung.DanhSachTrieuChung)
            {
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="DanhSachTrieuChung" value="@trieuChung"
                           id="@trieuChung" @(Model.DanhSachTrieuChung?.Contains(trieuChung) == true ? "checked" : "")>
                    <label class="form-check-label" for="@trieuChung">@trieuChung</label>
                </div>
            }
        </div>
    </div>

    <div class="form-group">
        <label asp-for="ChieuCao">Chiều cao (cm):</label>
        <input asp-for="ChieuCao" class="form-control" />
        <span asp-validation-for="ChieuCao" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="CanNang">Cân nặng (kg):</label>
        <input asp-for="CanNang" class="form-control" />
        <span asp-validation-for="CanNang" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Tham số K:</label>
        <input type="range" name="k" min="1" max="15" value="5" class="form-control-range"
               onchange="document.getElementById('kValue').innerText = this.value">
        <span id="kValue">5</span> hàng xóm
    </div>

    <button type="submit" class="btn btn-primary">Chẩn đoán</button>
</form>